{
  "permissions": {
    "allow": [
      "PowerShell(Get-ChildItem app -Recurse -Depth 2 | Where-Object {$_.Extension -eq '.py'} | Select-Object FullName)",
      "PowerShell(Get-ChildItem frontend -Depth 1 | Where-Object {$_.Name -ne 'node_modules'})",
      "PowerShell(.\\\\deploy.ps1 2>&1)",
      "Bash(curl -s -o /dev/null -w \"/coding-ta/types -> HTTP %{http_code}\\\\n\" https://lumen-demo.azurewebsites.net/coding-ta/types)",
      "Bash(curl -s -o /dev/null -w \"/coding-ta \\(SPA\\)  -> HTTP %{http_code}\\\\n\" https://lumen-demo.azurewebsites.net/coding-ta)"
    ]
  }
}
