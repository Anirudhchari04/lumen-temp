# Lumen v2 — environment variables.
#
# v2 reuses the EXISTING v1 .env / Azure App Service settings as-is. The repo has
# no root .env.example, and the v2 ground rules forbid touching files outside /v2,
# so this file documents v2-relevant vars here instead of editing a v1 file.
#
# ── Reused from v1 (already set for v1 — v2 reads, never writes these) ────────
# AZURE_OPENAI_ENDPOINT=https://<your-foundry>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-5.4
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_MANAGED_IDENTITY_CLIENT_ID=<uami-client-id>   # optional; else DefaultAzureCredential
# COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
# COSMOS_DATABASE=lumen-demo
# JWT_SECRET=<same secret v1 uses to sign/verify the bearer token>
#
# ── v2-specific (all optional; safe defaults) ─────────────────────────────────
# [v2] Cosmos container for v2 Task/Progress ledgers. MUST NOT be a v1 container.
LUMEN_V2_CONTAINER=lumen_v2_sessions
# [v2] Hard cap on Magentic-One orchestration turns per chat.
LUMEN_V2_MAX_TURNS=12
# [v2] Set to 0/false to skip mounting the v2 router (v1 is unaffected either way).
LUMEN_V2_ENABLED=1
